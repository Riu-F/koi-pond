  "license": "MIT",
  "homepage": "https://github.com/Riu-F/koi-pond",
  "repository": {
    "type": "git",
    "url": "https://github.com/Riu-F/koi-pond.git"
  },
  "keywords": [
    "koi",
    "pond",
    "canvas",
    "pixel-art",
    "react",
    "generative",
    "interactive",
    "animation",
    "fish"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
