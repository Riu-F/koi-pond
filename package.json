{
  "name": "koi-pond",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "An interactive pixel-art koi pond rendered to a single HTML canvas. Click to ripple, hold to feed, swipe to scatter. A dependency-free React component plus a live playground.",
